# Supabase Configuration
# These variables are required for the application to connect to Supabase

# Get these from your Supabase project settings
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Instructions:
# 1. Go to https://supabase.com and create a new project
# 2. Navigate to Project Settings > API
# 3. Copy the Project URL to VITE_SUPABASE_URL
# 4. Copy the Anon (public) key to VITE_SUPABASE_ANON_KEY
# 5. Rename this file from .env.example to .env
# 6. Run: npm install
# 7. Run: npm run dev
